<Window x:Class="RubyArena_Launcher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RubyArena_Launcher"
        mc:Ignorable="d"
        Title="MainWindow" Height="600" Width="800" Icon="/yang.png" ResizeMode="CanMinimize">
    <Grid Margin="0,0,0,0">

        <Image Margin="0,0,0,0" Source="/background.png" Stretch="Fill" Opacity="0.8"/>
        <Rectangle Stroke="Black" StrokeThickness="10" Fill="DimGray" Margin="0,485,0,0"/>
        <Button Name="PlayButton" Content="Play" FontSize="25"
                FontFamily="Arial Black" Click="PlayButtonClick" Margin="300,495,332,10"/>
        <ScrollViewer x:Name="ScrollView"  Margin="0,0,0,71"  FontFamily="Bahnschrift" FontSize="30" UseLayoutRounding="False">
        
        <TextBlock x:Name="StaticPatchText" TextWrapping="WrapWithOverflow" Text="TextBlock"/>
        
        </ScrollViewer>
        <Grid x:Name="WebViewerHost" Margin="0,0,0,71"/>


    </Grid>
</Window>
