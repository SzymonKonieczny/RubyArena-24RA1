<Window x:Class="RubyArena_Launcher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RubyArena_Launcher"
        mc:Ignorable="d"
        Title="MainWindow" Height="600" Width="800" Icon="/yang.png" ResizeMode="CanMinimize">
    <Grid Margin="0,0,0,0">

        <Image Margin="0,0,0,0" Source="/yang.png" Stretch="Fill"/>
        <Rectangle Stroke="Black" StrokeThickness="10" Margin="0,513,10,0" Fill="DimGray"/>
        <Button Name="PlayButton" Content="Play" HorizontalAlignment="Left" Width="168" FontSize="25"
                FontFamily="Arial Black" Click="PlayButtonClick" Height="51" VerticalAlignment="Bottom" Margin="300,0,0,10"/>
        <ScrollViewer x:Name="ScrollView" Margin="0,0,0,71" Content="TEWST VALES" FontFamily="Times New Roman" FontSize="30">
        </ScrollViewer>
        <WebBrowser x:Name="WebViewer" Source="https://www.youtube.com" Margin="0,0,0,71"/>


    </Grid>
</Window>
