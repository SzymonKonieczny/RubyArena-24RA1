<Window x:Class="RubyArena_Launcher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RubyArena_Launcher"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid>
        <Image HorizontalAlignment="Left" Height="450" Width="800" Source="yang.png" Stretch="Fill"/>
        <Rectangle Stroke="Black" StrokeThickness="10" Margin="0,363,10,0" Fill="DimGray"/>

        <Button Name="PlayButton" Content="Play" HorizontalAlignment="Left" Height="51" Margin="301,373,0,0" VerticalAlignment="Top" Width="168" FontSize="25"
                FontFamily="Arial Black" Click="PlayButtonClick"/>


    </Grid>
</Window>
